# ─────────────────────────────────────────────────────────────
# GitManager — Environment Variables
# Copy this file to .env and fill in your values
# ─────────────────────────────────────────────────────────────
APP_ENV=development
LOG_DIR=logs
DATA_DIR=data
API_HOST=127.0.0.1
API_PORT=8000
GIT_AUTO_PUSH=true
GIT_BRANCH=main
SYNC_INTERVAL_MINUTES=10
SYNC_POLL_SECONDS=60
GM_USERNAME=admin
GM_PASSWORD=123456

