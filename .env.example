# ─────────────────────────────────────────────────────────────
# GitManager — Environment Variables
# Copy this file to .env and fill in your values.
# All variables below are REQUIRED for the application to start.
# ─────────────────────────────────────────────────────────────

# Application Environment (development/production)
APP_ENV=development

# Directory Paths (Relative to project root or absolute)
LOG_DIR=logs
DATA_DIR=data

# API Server Configuration
API_HOST=127.0.0.1
API_PORT=8000

# Git Defaults for New Projects
GIT_AUTO_PUSH=true
GIT_BRANCH=main

# Sync Scheduler Settings
SYNC_INTERVAL_MINUTES=10
SYNC_POLL_SECONDS=60

# Web Dashboard Authentication
GM_USERNAME=admin
GM_PASSWORD=admin_password_change_me
